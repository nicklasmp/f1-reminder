# ─── Supabase ────────────────────────────────────────────────────────────────
# Find disse under: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Web Push / VAPID ────────────────────────────────────────────────────────
# Generer med: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:din@email.com

# ─── Cron sikkerhed ──────────────────────────────────────────────────────────
# Valgfri lang tilfældig streng — send som x-cron-secret header fra cron-job.org
# Generer med: openssl rand -hex 32
CRON_SECRET=en-lang-tilfaeldig-streng
